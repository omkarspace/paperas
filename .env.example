# =============================================================================
# Paperas — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Database (SQLite for dev, PostgreSQL for production)
# -----------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/paperas"

# -----------------------------------------------------------------------------
# Auth.js
# -----------------------------------------------------------------------------
AUTH_SECRET="generate-a-secret-at-https://authjs.dev/docs/getting-started#1-configure-authjs"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAuth Providers (optional — leave blank to disable)
# -----------------------------------------------------------------------------
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ORCID OAuth: https://info.orcid.org/documentation/features/developer-tools
ORCID_CLIENT_ID=""
ORCID_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Email (Resend) — Required for password reset, notifications
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Paperas <noreply@paperas.in>"

# -----------------------------------------------------------------------------
# File Storage (AWS S3) — Required for PDF uploads
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="ap-south-1"

# -----------------------------------------------------------------------------
# Search (Typesense) — Optional, falls back to Prisma
# -----------------------------------------------------------------------------
TYPESENSE_HOST=""
TYPESENSE_API_KEY=""

# -----------------------------------------------------------------------------
# AI (Google Gemini) — Optional, for abstract summaries and keyword extraction
# -----------------------------------------------------------------------------
GEMINI_API_KEY=""

# -----------------------------------------------------------------------------
# DOI Registration (CrossRef) — Optional, for automatic DOI assignment
# -----------------------------------------------------------------------------
CROSSREF_DEPOSIT_EMAIL=""
CROSSREF_USERNAME=""
CROSSREF_PASSWORD=""
