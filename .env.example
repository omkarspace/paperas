# =============================================================================
# Paperas — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------------------
# Database (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# Use the Pooler connection string from your Supabase dashboard:
# Dashboard → Settings → Database → Connection string → Pooler
# For Prisma: use the Transaction mode (port 6543) URL
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR-POOLER-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# -----------------------------------------------------------------------------
# Supabase (Auth + Storage)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Email (Resend) — Required for password reset, notifications
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="Paperas <noreply@paperas.in>"

# -----------------------------------------------------------------------------
# Rate Limiting (Upstash Redis) — Recommended for production
# Free tier: https://upstash.com — 10,000 commands/day
# Without this, uses in-memory rate limiting (fine for single-instance dev)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Search (Typesense) — Optional, falls back to Prisma
# -----------------------------------------------------------------------------
TYPESENSE_HOST=""
TYPESENSE_API_KEY=""

# -----------------------------------------------------------------------------
# AI (Google Gemini) — Optional, for abstract summaries and keyword extraction
# -----------------------------------------------------------------------------
GEMINI_API_KEY=""

# -----------------------------------------------------------------------------
# DOI Registration (CrossRef) — Optional, for automatic DOI assignment
# -----------------------------------------------------------------------------
CROSSREF_DEPOSIT_EMAIL=""
CROSSREF_USERNAME=""
CROSSREF_PASSWORD=""
